# Primary LLM (Google Gemini recommended)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_PROJECT_ID=your-gcp-project-id

# Fallback LLM (Optional)
OPENAI_API_KEY=your-openai-key-here

# Trend Intelligence (existing flows 1-3)
TWITTER_METHOD=scraping  # api|scraping|disabled
TWITTER_BEARER_TOKEN=your-twitter-bearer-token  # Only if using API
PERPLEXITY_API_KEY=your-perplexity-key

# Flow 4: Trend Research (standalone)
TWITTERAPI_IO_KEY=your-twitterapi-io-key-here   # Get from https://twitterapi.io/dashboard

# Paths (adjust as needed)
BRAND_KNOWLEDGE_PATH=./brand_knowledge    # RAG source documents directory
RAG_INDEX_PATH=./.cache/rag_index         # FAISS index cache directory
BRAND_IDENTITY_PATH=./brand_identity
MEME_TEMPLATES_PATH=./rekt_meme_templates
OUTPUT_PATH=./output

# Caching
FORCE_REFRESH_CONTEXT=false  # Set true to ignore business context cache
FORCE_REFRESH_TRENDS=false   # Set true to ignore 1-hour trend cache
TREND_CACHE_HOURS=1          # Cache expiry for trends (in hours)

# Twitter Account Settings
TWITTER_ACCOUNT_TYPE=standard  # standard|premium (affects char limit: 280 vs 4000)

# Content Generation Settings
CONTENT_VARIATIONS=1  # Number of variations per platform
SKIP_ANIMATION=false  # Set true to skip animation (faster execution)

# Animation Settings
ANIMATION_METHOD=veo3  # veo3|nano_banana|traditional
ANIMATION_STYLE=auto   # auto|blink|bounce|shake|glow|zoom|none

SUPABASE_URL=
SUPABASE_SERVICE_KEY=