# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=false

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# File Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_IMAGE_FORMATS=image/jpeg,image/png,image/webp

# LLM API Keys (configure one or more — users pick model per request via `llm` field)
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Server default when client omits `llm` (gemini-flash recommended)
DEFAULT_LLM=gemini-flash
# Fallback for image analysis when chosen preset lacks vision (e.g. groq, deepseek)
DEFAULT_VISION_LLM=gemini-flash

# Optional: Brand Configuration Path
BRAND_CONFIG_PATH=../content-meme-automation/brand_identity/brand_config.json
MEME_TEMPLATES_PATH=../content-meme-automation/rekt_meme_templates

# Logging
LOG_LEVEL=INFO

# x402 payments (set X402_ENABLED=true in production)
X402_ENABLED=false
X402_PRICE=$0.05
X402_EVM_PAY_TO=0xYourEvmWalletAddress
# Optional: also accept Solana USDC payments
# X402_SVM_PAY_TO=YourSolanaWalletAddress
X402_EVM_NETWORK=eip155:84532
# X402_SVM_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_FACILITATOR_URL=https://x402.org/facilitator
# Mainnet: eip155:8453 + https://facilitator.payai.network or Coinbase CDP facilitator

# Admin free access (long random secret — never commit the real value)
ADMIN_API_KEY=change-me-to-a-long-random-secret
